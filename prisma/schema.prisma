generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Booking {
  id          String   @id @default(uuid())
  date        String
  time        String
  name        String
  email       String
  phone       String?
  address     String?
  description String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}
